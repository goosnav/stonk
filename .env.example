# Copy to .env and fill in. NEVER commit .env.

# --- Live trading master switch (must ALSO be enabled in config) ---
LIVE_TRADING_ENABLED=false
# Comma-separated Robinhood account IDs the engine may touch. Empty = refuse all live orders.
RH_ACCOUNT_WHITELIST=

# --- AI (optional; system runs fully deterministic without it) ---
# Provider-agnostic key + base URL. The GUI (Risk/Config page → "AI provider &
# key") writes these two live; you can also set them by hand here. All providers
# use the OpenAI-compatible chat API, so only these two values change:
#   OpenRouter  https://openrouter.ai/api/v1
#   OpenAI      https://api.openai.com/v1
#   Anthropic   https://api.anthropic.com/v1   (Claude, OpenAI-compat endpoint)
AI_API_KEY=
AI_BASE_URL=https://openrouter.ai/api/v1
# Legacy fallback: used only if AI_API_KEY is unset.
OPENROUTER_API_KEY=

# --- Data (all optional; free sources used by default) ---
FRED_API_KEY=
